    },
    {
      "name": "__DEEP_PROJECT__",
      "platform": "feishu",
      "mode": "mention_deep",
      "model": "__DEEP_MODEL__"
    }
  ],
  "commands": [
    "/help",
    "/dream",
    "/status-index",
    "/health-codex-feishu",
    "/files",
